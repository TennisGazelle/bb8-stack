<?xml version="1.0"?>
<robot name="bb8" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!--
    Milestone 2 URDF target:
      - robot_state_publisher has a frame tree matching the Gazebo model intent
      - shell, internal ballast, IMU, and camera frames exist
      - physical simulation still comes from sim/models/bb8_rolling_sphere/model.sdf
  -->

  <xacro:property name="shell_radius" value="0.18"/>
  <xacro:property name="shell_mass" value="1.20"/>
  <xacro:property name="shell_inertia" value="0.015552"/>
  <xacro:property name="ballast_mass" value="0.45"/>
  <xacro:property name="ballast_inertia" value="0.00085"/>

  <material name="bb8_shell_white">
    <color rgba="0.94 0.91 0.84 1.0"/>
  </material>

  <material name="bb8_ballast_dark">
    <color rgba="0.08 0.08 0.09 0.55"/>
  </material>

  <link name="base_link"/>

  <joint name="base_to_shell" type="fixed">
    <parent link="base_link"/>
    <child link="bb8_shell"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="bb8_shell">
    <visual>
      <geometry>
        <sphere radius="${shell_radius}"/>
      </geometry>
      <material name="bb8_shell_white"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${shell_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${shell_mass}"/>
      <inertia
        ixx="${shell_inertia}" ixy="0" ixz="0"
        iyy="${shell_inertia}" iyz="0"
        izz="${shell_inertia}"/>
    </inertial>
  </link>

  <joint name="shell_to_internal_ballast" type="fixed">
    <parent link="bb8_shell"/>
    <child link="internal_ballast"/>
    <origin xyz="0 0 -0.07" rpy="0 0 0"/>
  </joint>

  <link name="internal_ballast">
    <visual>
      <geometry>
        <box size="0.12 0.08 0.04"/>
      </geometry>
      <material name="bb8_ballast_dark"/>
    </visual>
    <inertial>
      <mass value="${ballast_mass}"/>
      <inertia
        ixx="${ballast_inertia}" ixy="0" ixz="0"
        iyy="${ballast_inertia}" iyz="0"
        izz="${ballast_inertia}"/>
    </inertial>
  </link>

  <joint name="shell_to_imu" type="fixed">
    <parent link="bb8_shell"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="imu_link"/>

  <joint name="shell_to_camera" type="fixed">
    <parent link="bb8_shell"/>
    <child link="camera_link"/>
    <origin xyz="0.10 0 0.10" rpy="0 0 0"/>
  </joint>

  <link name="camera_link"/>
</robot>
