<?xml version="1.0"?>
<model>
  <name>bb8_rolling_sphere</name>
  <version>0.0.1</version>
  <sdf version="1.10">model.sdf</sdf>
  <author>
    <name>TennisGazelle</name>
    <email>todo@example.com</email>
